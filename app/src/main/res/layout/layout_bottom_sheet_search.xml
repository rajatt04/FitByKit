                <com.google.android.material.chip.Chip
                    android:id="@+id/chipGreek"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🇬🇷 Greek" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipIndian"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🇮🇳 Indian" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipIrish"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🇮🇪 Irish" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipItalian"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🇮🇹 Italian" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipJamaican"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🇯🇲 Jamaican" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipJapanese"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🇯🇵 Japanese" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipKenyan"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🇰🇪 Kenyan" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMalaysian"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🇲🇾 Malaysian" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMexican"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🇲🇽 Mexican" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMoroccan"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🇲🇦 Moroccan" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPolish"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🇵🇱 Polish" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPortuguese"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🇵🇹 Portuguese" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRussian"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🇷🇺 Russian" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSpanish"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🇪🇸 Spanish" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipThai"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🇹🇭 Thai" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTunisian"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🇹🇳 Tunisian" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTurkish"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🇹🇷 Turkish" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipVietnamese"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🇻🇳 Vietnamese" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- ── Divider ── -->
        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <!-- ── Browse by Name Section ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="12dp"
            android:text="🔤  Browse by Name"
            android:fontFamily="@font/poppins"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/letterChipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="20dp"
            app:singleSelection="true"
            app:chipSpacingHorizontal="4dp"
            app:chipSpacingVertical="4dp">


            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="A" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipB"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="B" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="C" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipD"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="D" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipE"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="E" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="F" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipG"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="G" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipH"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="H" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipI"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="I" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipJ"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="J" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipK"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="K" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipL"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="L" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipM"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="M" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipN"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="N" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipO"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="O" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipP"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="P" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipQ"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="Q" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="R" />

            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="S" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipT"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="T" />
            <com.google.android.material.chip.Chip
