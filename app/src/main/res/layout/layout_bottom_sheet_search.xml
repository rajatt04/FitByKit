                android:id="@+id/chipU"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="U" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="V" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipW"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="W" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipX"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="X" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipY"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="Y" />
            <com.google.android.material.chip.Chip
                style="@style/LetterChip"
                android:id="@+id/chipZ"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
