<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="350dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardBackgroundColor="#1C1C1E"
    app:cardElevation="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="32dp">

        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FitByKit"
            android:textColor="#2D72F3"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today's Crush"
            android:textColor="#8E8E93"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@+id/tvAppTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvAppTitle" />

        <!-- Main Stats Circle -->
        <View
            android:id="@+id/ring"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="@drawable/circle_outlined"
            android:layout_marginTop="32dp"
            android:backgroundTint="#2D72F3"
            app:layout_constraintTop_toBottomOf="@+id/tvAppTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvShareSteps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10,245"
            android:textColor="@color/white"
            android:textSize="48sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/tvStepsLabel"
            app:layout_constraintEnd_toEndOf="@+id/ring"
            app:layout_constraintStart_toStartOf="@+id/ring"
            app:layout_constraintTop_toTopOf="@+id/ring"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/tvStepsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEPS"
            android:textColor="#2D72F3"
            android:textSize="14sp"
            android:letterSpacing="0.2"
            app:layout_constraintBottom_toBottomOf="@+id/ring"
            app:layout_constraintEnd_toEndOf="@+id/ring"
            app:layout_constraintStart_toStartOf="@+id/ring"
            app:layout_constraintTop_toBottomOf="@+id/tvShareSteps" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            android:weightSum="3"
            app:layout_constraintTop_toBottomOf="@+id/ring">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvShareCal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="450"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kcal"
                    android:textSize="12sp"
                    android:textColor="#8E8E93"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvShareDist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5.2"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Km"
                    android:textSize="12sp"
                    android:textColor="#8E8E93"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvShareTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="45"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mins"
                    android:textSize="12sp"
                    android:textColor="#8E8E93"/>
            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
